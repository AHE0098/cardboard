{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cardboard.local/schema/deck.schema.json",
  "title": "Deck",
  "type": "object",
  "required": ["deckId", "name", "cards"],
  "properties": {
    "deckId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "cards": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["cardId"],
            "properties": {
              "cardId": { "type": "string", "minLength": 1 },
              "count": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "maxCopies": { "type": "integer", "minimum": 1 },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
